# Prisma validation and env loading use these values in local development.
DATABASE_URL=postgresql://portal:portal@localhost:5432/portal?schema=public
AUTH_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=replace-me
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/tenant/v2.0

# Optional portal-managed GitHub repository bootstrap settings
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_ALLOWED_ORGS=cedarville-it
GITHUB_DEFAULT_ORG=cedarville-it
GITHUB_DEFAULT_REPO_VISIBILITY=private
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_INSTALLATIONS_JSON=

# Optional portal-managed Azure publishing settings for generated user apps
AZURE_PUBLISH_RESOURCE_GROUP=rg-cu-apps-published
AZURE_PUBLISH_APP_SERVICE_PLAN=asp-cu-apps-published
AZURE_PUBLISH_POSTGRES_SERVER=psql-cu-apps-published
AZURE_PUBLISH_POSTGRES_ADMIN_USER=
AZURE_PUBLISH_POSTGRES_ADMIN_PASSWORD=
AZURE_PUBLISH_LOCATION=eastus2
AZURE_PUBLISH_RUNTIME_STACK=NODE|24-lts
AZURE_PUBLISH_CLIENT_ID=
AZURE_PUBLISH_TENANT_ID=
AZURE_PUBLISH_SUBSCRIPTION_ID=
AZURE_PUBLISH_AUTH_SECRET=
AZURE_PUBLISH_ENTRA_CLIENT_ID=
AZURE_PUBLISH_ENTRA_CLIENT_SECRET=
AZURE_PUBLISH_ENTRA_ISSUER=https://login.microsoftonline.com/tenant/v2.0
AZURE_PUBLISH_ENTRA_APP_OBJECT_ID=
